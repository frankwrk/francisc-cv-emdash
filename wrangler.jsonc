{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "francisc-cv-emdash",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "francisc-cv-emdash-db",
			// Run `wrangler d1 create my-emdash-site` and paste the real ID here for deploy
			"database_id": "d25c3413-7350-4251-8d25-721875467543",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "francisc-cv-emdash-media","preview_bucket_name": "francisc-cv-emdash-media",
		},
	],
	// Worker Loader for plugin sandboxing
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}
